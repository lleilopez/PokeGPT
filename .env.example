# ─── Configuración general del proyecto ──────────────────────────────────────
# Copia este archivo como .env y ajusta los valores a tu entorno local.
# Nunca subas .env al repositorio.

# Semilla para reproducibilidad
SEED=42

# Dispositivo de entrenamiento: "cpu" o "cuda"
DEVICE=cpu

# ─── Rutas ────────────────────────────────────────────────────────────────────
DATA_DIR=data
CHECKPOINTS_DIR=checkpoints
LOGS_DIR=logs

# ─── Hiperparámetros por defecto ──────────────────────────────────────────────
BATCH_SIZE=32
LEARNING_RATE=3e-4
MAX_EPOCHS=100
CONTEXT_LENGTH=128
EMBED_DIM=128
NUM_HEADS=4
NUM_LAYERS=2
DROPOUT=0.1
